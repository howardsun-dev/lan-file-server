{
  "name": "lanshare",
  "version": "1.0.0",
  "description": "LANShare: TypeScript HTTP server for sharing a folder on your LAN with a minimalist web UI.",
  "type": "module",
  "main": "dist/src/server.js",
  "types": "dist/src/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/server.d.ts",
      "import": "./dist/src/server.js"
    }
  },
  "bin": {
    "lanshare": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/src/cli.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:functional": "vitest run tests/functional",
    "check": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "lan",
    "file-server",
    "typescript",
    "http",
    "static-files"
  ],
  "author": "Howard Sun",
  "homepage": "https://github.com/howardsun-dev/LANShare#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howardsun-dev/LANShare.git"
  },
  "bugs": {
    "url": "https://github.com/howardsun-dev/LANShare/issues"
  },
  "license": "MIT",
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "mime-types": "^3.0.2",
    "serve-static": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.5",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "playwright": "^1.56.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.8"
  }
}
